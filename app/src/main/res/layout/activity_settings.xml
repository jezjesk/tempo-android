<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/spark_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚙ Settings"
            android:textColor="@color/spark_yellow"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Configure how offers are evaluated and acted on"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:layout_marginBottom="32dp"/>

        <!-- ── Trip Criteria Card ── -->
        <androidx.cardview.widget.CardView
            xmlns:card_view="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            card_view:cardBackgroundColor="@color/spark_surface"
            card_view:cardCornerRadius="16dp"
            card_view:cardElevation="4dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Trip Criteria"
                    android:textColor="@color/spark_yellow"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="All criteria must be met to accept an offer. Any failure = reject."
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:lineSpacingMultiplier="1.4"
                    android:layout_marginBottom="20dp"/>

                <!-- Minimum Tip Amount -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Minimum Tip Amount ($)"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:layout_marginBottom="4dp"/>
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxStrokeColor="@color/text_secondary"
                    app:hintTextColor="@color/text_secondary">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etMinTipAmount"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:textColor="@color/white"
                        android:hint="e.g. 2.00"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Minimum Tip Hourly -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Minimum Tip Hourly ($/hr)"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:layout_marginBottom="4dp"/>
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxStrokeColor="@color/text_secondary"
                    app:hintTextColor="@color/text_secondary">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etMinTipHourly"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:textColor="@color/white"
                        android:hint="e.g. 5.00"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Minimum Total Pay -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Minimum Total Pay ($)"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:layout_marginBottom="4dp"/>
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxStrokeColor="@color/text_secondary"
                    app:hintTextColor="@color/text_secondary">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etMinTotalPay"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:textColor="@color/white"
                        android:hint="e.g. 8.00"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Minimum Hourly Pay -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Minimum Hourly Pay ($/hr)"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:layout_marginBottom="4dp"/>
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxStrokeColor="@color/text_secondary"
                    app:hintTextColor="@color/text_secondary">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etMinPayHourly"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:textColor="@color/white"
                        android:hint="e.g. 15.00"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Maximum Distance -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Maximum Distance (miles)"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:layout_marginBottom="4dp"/>
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxStrokeColor="@color/text_secondary"
                    app:hintTextColor="@color/text_secondary">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etMaxDistance"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:textColor="@color/white"
                        android:hint="e.g. 20.0"/>
                </com.google.android.material.textfield.TextInputLayout>

                  <!-- Minimum Dollars Per Mile -->
                  <TextView
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:text="Minimum Pay Per Mile ($/mi)"
                      android:textColor="@color/white"
                      android:textSize="13sp"
                      android:layout_marginBottom="4dp"/>
                  <com.google.android.material.textfield.TextInputLayout
                      android:layout_width="match_parent"
                      android:layout_height="wrap_content"
                      android:layout_marginBottom="4dp"
                      style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                      app:boxStrokeColor="@color/text_secondary"
                      app:hintTextColor="@color/text_secondary">
                      <com.google.android.material.textfield.TextInputEditText
                          android:id="@+id/etMinDollarsPerMile"
                          android:layout_width="match_parent"
                          android:layout_height="wrap_content"
                          android:inputType="numberDecimal"
                          android:textColor="@color/white"
                          android:hint="e.g. 1.00"/>
                  </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>


          <!-- ── Quick Mode Card ── -->
          <androidx.cardview.widget.CardView
              xmlns:card_view="http://schemas.android.com/apk/res-auto"
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              card_view:cardBackgroundColor="@color/spark_surface"
              card_view:cardCornerRadius="16dp"
              card_view:cardElevation="4dp"
              android:layout_marginBottom="16dp">

              <LinearLayout
                  android:layout_width="match_parent"
                  android:layout_height="wrap_content"
                  android:orientation="vertical"
                  android:padding="20dp">

                  <TextView
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:text="Quick Mode"
                      android:textColor="@color/spark_yellow"
                      android:textSize="16sp"
                      android:textStyle="bold"
                      android:layout_marginBottom="4dp"/>

                  <TextView
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                  android:text="Accept offers directly from the home card — no detail screen. Only triggers when estimated pay/hr AND $/mi AND estimated total all meet the thresholds below."
                      android:textColor="@color/text_secondary"
                      android:textSize="12sp"
                      android:lineSpacingMultiplier="1.4"
                      android:layout_marginBottom="16dp"/>

                  <LinearLayout
                      android:layout_width="match_parent"
                      android:layout_height="wrap_content"
                      android:orientation="horizontal"
                      android:gravity="center_vertical"
                      android:layout_marginBottom="16dp">

                      <TextView
                          android:layout_width="0dp"
                          android:layout_height="wrap_content"
                          android:layout_weight="1"
                          android:text="Enable Quick Mode"
                          android:textColor="@color/white"
                          android:textSize="14sp"/>

                      <androidx.appcompat.widget.SwitchCompat
                          android:id="@+id/swQuickMode"
                          android:layout_width="wrap_content"
                          android:layout_height="wrap_content"/>
                  </LinearLayout>

                  <TextView
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:text="Quick Accept Min Hourly ($/hr)"
                      android:textColor="@color/white"
                      android:textSize="13sp"
                      android:layout_marginBottom="4dp"/>
                  <com.google.android.material.textfield.TextInputLayout
                      android:layout_width="match_parent"
                      android:layout_height="wrap_content"
                      android:layout_marginBottom="4dp"
                      style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                      app:boxStrokeColor="@color/text_secondary"
                      app:hintTextColor="@color/text_secondary">
                      <com.google.android.material.textfield.TextInputEditText
                          android:id="@+id/etQuickMinHourly"
                          android:layout_width="match_parent"
                          android:layout_height="wrap_content"
                          android:inputType="numberDecimal"
                          android:textColor="@color/white"
                          android:hint="e.g. 50"/>
                  </com.google.android.material.textfield.TextInputLayout>

                  <TextView
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:text="Quick Accept Min Estimated Total ($)"
                      android:textColor="@color/white"
                      android:textSize="13sp"
                      android:layout_marginTop="8dp"
                      android:layout_marginBottom="4dp"/>
                  <com.google.android.material.textfield.TextInputLayout
                      android:layout_width="match_parent"
                      android:layout_height="wrap_content"
                      android:layout_marginBottom="4dp"
                      style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                      app:boxStrokeColor="@color/text_secondary"
                      app:hintTextColor="@color/text_secondary">
                      <com.google.android.material.textfield.TextInputEditText
                          android:id="@+id/etQuickMinEstTotal"
                          android:layout_width="match_parent"
                          android:layout_height="wrap_content"
                          android:inputType="numberDecimal"
                          android:textColor="@color/white"
                          android:hint="e.g. 25.00"/>
                  </com.google.android.material.textfield.TextInputLayout>

              </LinearLayout>
          </androidx.cardview.widget.CardView>

            <!-- ── Home Pre-Reject Card ── -->
            <androidx.cardview.widget.CardView
                xmlns:card_view="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                card_view:cardBackgroundColor="@color/spark_surface"
                card_view:cardCornerRadius="16dp"
                card_view:cardElevation="4dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Home Card Pre-Reject"
                        android:textColor="@color/spark_yellow"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Reject offers directly from the home card when they are clearly below your criteria. Set the threshold as a percentage (0–100). 0 = off. 60 = reject if estimated hourly OR total is below 60% of your minimums."
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:lineSpacingMultiplier="1.4"
                        android:layout_marginBottom="16dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pre-Reject Threshold (%, 0 = off)"
                        android:textColor="@color/white"
                        android:textSize="13sp"
                        android:layout_marginBottom="4dp"/>
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:boxStrokeColor="@color/text_secondary"
                        app:hintTextColor="@color/text_secondary">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etHomeRejectThreshold"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal"
                            android:textColor="@color/white"
                            android:hint="e.g. 60"/>
                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>
  
          <!-- ── Delay Criteria Card ── -->
        <androidx.cardview.widget.CardView
            xmlns:card_view="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            card_view:cardBackgroundColor="@color/spark_surface"
            card_view:cardCornerRadius="16dp"
            card_view:cardElevation="4dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Delay Criteria"
                    android:textColor="@color/spark_yellow"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="A random delay within each range is chosen at runtime to simulate human behavior."
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:lineSpacingMultiplier="1.4"
                    android:layout_marginBottom="20dp"/>

                <!-- Click to Details -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Click to Details (ms)"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:boxStrokeColor="@color/text_secondary"
                        app:hintTextColor="@color/text_secondary"
                        android:hint="Min">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etDetailsDelayMin"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:textColor="@color/white"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:boxStrokeColor="@color/text_secondary"
                        app:hintTextColor="@color/text_secondary"
                        android:hint="Max">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etDetailsDelayMax"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:textColor="@color/white"/>
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <!-- Click Accept -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Click Accept (ms)"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:boxStrokeColor="@color/text_secondary"
                        app:hintTextColor="@color/text_secondary"
                        android:hint="Min">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etAcceptDelayMin"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:textColor="@color/white"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:boxStrokeColor="@color/text_secondary"
                        app:hintTextColor="@color/text_secondary"
                        android:hint="Max">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etAcceptDelayMax"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:textColor="@color/white"/>
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <!-- Click Reject -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Click Reject (ms)"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:boxStrokeColor="@color/text_secondary"
                        app:hintTextColor="@color/text_secondary"
                        android:hint="Min">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etRejectDelayMin"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:textColor="@color/white"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:boxStrokeColor="@color/text_secondary"
                        app:hintTextColor="@color/text_secondary"
                        android:hint="Max">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etRejectDelayMax"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:textColor="@color/white"/>
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Save Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save Settings"
            android:textColor="@color/spark_dark"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="@color/spark_yellow"
            app:cornerRadius="12dp"
            android:layout_marginBottom="16dp"/>

    </LinearLayout>
</ScrollView>
